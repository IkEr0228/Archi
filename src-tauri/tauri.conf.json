{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "archi",
  "version": "0.2.0",
  "identifier": "com.archi.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Archi",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "focus": true,
        "resizable": true,
        "backgroundColor": "#0a0a0c",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,CalculateNativeWinOcclusion --disable-background-networking --disable-component-update --disable-default-apps --disable-domain-reliability --disable-sync --no-first-run --disable-renderer-backgrounding --disable-background-timer-throttling --disable-breakpad --disable-client-side-phishing-detection --disable-hang-monitor --disable-popup-blocking --disable-prompt-on-repost --metrics-recording-only"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
